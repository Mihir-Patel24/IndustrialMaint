# ================================================================
# .env.example — IndustrialMaint AI Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ================================================================

# ── Supabase (Optional — SQLite used if not set) ────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ── Security ────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# ── App Mode ────────────────────────────────────────────────────
# Set to "false" to disable demo login bypass
DEMO_MODE=true

# ── Authentication & Session ─────────────────────────────────────
# How long the authenticated session stays active (hours)
SESSION_TIMEOUT_HOURS=24
# How long a password-reset token is valid (hours)
PW_RESET_EXPIRY_HOURS=1

# ── Email / Notifications (Optional) ────────────────────────────
# Leave SMTP_HOST blank to disable email notifications entirely.
# Gmail: use an App Password (not your account password).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
# Default recipient for alert and summary emails
ALERT_EMAIL=engineer@yourcompany.com

# ── Roles (informational — do not set as env vars) ──────────────
# Available roles: Admin | Plant Manager | Maintenance Engineer | Operator
# Role is set per-user during registration and editable via Profile page.
# Role hierarchy: Admin > Plant Manager > Maintenance Engineer > Operator

# ── Streamlit Cloud Deployment ──────────────────────────────────
# Add all secrets above in Streamlit Cloud → Settings → Secrets
# Required for cloud: SUPABASE_URL, SUPABASE_ANON_KEY, SECRET_KEY, DEMO_MODE
